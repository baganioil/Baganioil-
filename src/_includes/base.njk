    <!-- Floating Navbar Script -->
    <script>
    (function() {
      var wrap = document.getElementById('bagani-header-wrap');
      var spacer = document.getElementById('header-spacer');

      function syncSpacer() {
        if (spacer && wrap) spacer.style.height = wrap.offsetHeight + 'px';
      }

      function onScroll() {
        var scrollY = window.scrollY || window.pageYOffset;
        if (scrollY > 40) {
          wrap.classList.add('scrolled');
        } else {
          wrap.classList.remove('scrolled');
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', syncSpacer);
      document.addEventListener('DOMContentLoaded', function() {
        syncSpacer();
        onScroll();

        // Nike-style search drawer toggle
        var searchToggle = document.getElementById('nikeSearchToggle');
        var searchDrawer = document.getElementById('nikeSearchDrawer');
        var searchClose = document.getElementById('nikeSearchClose');
        var searchInput = document.getElementById('nikeSearchInput');

        if (searchToggle && searchDrawer) {
          searchToggle.addEventListener('click', function() {
            searchDrawer.classList.toggle('open');
            if (searchDrawer.classList.contains('open') && searchInput) {
              setTimeout(function() { searchInput.focus(); }, 100);
            }
          });
        }
        if (searchClose && searchDrawer) {
          searchClose.addEventListener('click', function() {
            searchDrawer.classList.remove('open');
          });
        }
      });
      // re-sync after fonts/images load
      window.addEventListener('load', syncSpacer);
    })();
    </script>

    <!-- Language Toggle Script -->
    <script>
      // Swap all elements that have data-en and data-tl attributes
      function applyLang(lang) {
        document.querySelectorAll('[data-en]').forEach(function(el) {
          el.textContent = lang === 'tl' ? (el.getAttribute('data-tl') || el.getAttribute('data-en')) : el.getAttribute('data-en');
        });
        var btn = document.getElementById('langToggle');
        if (btn) {
          btn.textContent = lang === 'tl' ? 'Tagalog' : 'English';
          btn.style.color = lang === 'tl' ? '#222222' : '#FFFFFF';
          btn.style.background = lang === 'tl' ? '#FFC107' : 'none';
        }
        document.documentElement.setAttribute('lang', lang === 'tl' ? 'tl' : 'en');
        localStorage.setItem('bagani-lang', lang);
      }

      function toggleLang() {
        var current = localStorage.getItem('bagani-lang') || 'en';
        applyLang(current === 'en' ? 'tl' : 'en');
      }

      // Apply saved preference on load
      document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('bagani-lang') || 'en';
        if (saved === 'tl') applyLang('tl');
      });
    </script>

    <!-- Netlify Identity Redirect -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>

    {% if site.facebookPageId and site.facebookPageId != "YOUR_FACEBOOK_PAGE_ID" %}
    <!-- Bagani AI Chatbot Widget -->
    <style>
      /* ── Wrap ── */
      .bagani-chat-wrap {
        position: fixed; bottom: 24px; right: 24px; z-index: 9998;
        display: flex; align-items: flex-end; justify-content: flex-end;
      }

      /* ── Popup window (Bagani Dark Glass) ── */
      .bagani-chat-popup {
        width: 360px; height: 520px;
        background: rgba(28,28,28,0.95);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        overflow: hidden; 
        transform: scale(0.95) translateY(10px) translateX(10px);
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: bottom right;
        display: flex; flex-direction: column;
        position: absolute; bottom: 0; right: 0;
      }
      .bagani-chat-popup.open { opacity: 1; transform: scale(1) translateY(0) translateX(0); pointer-events: all; }

      /* Watermark */
      .bagani-chat-bg-watermark {
        position: absolute; top: 18%; left: 0; width: 100%;
        text-align: center; color: rgba(255,255,255,0.03);
        font-size: 64px; font-weight: 800; font-family: "Inter", sans-serif;
        pointer-events: none; z-index: 0; letter-spacing: 2px;
        text-transform: uppercase;
      }

      /* ── Header ── */
      .bagani-chat-header {
        padding: 24px 24px 10px 24px; 
        display: flex; align-items: center; justify-content: space-between;
        z-index: 10;
      }
      .bagani-chat-logo-img {
        max-width: 100px;
        max-height: 28px;
        object-fit: contain;
      }
      .bagani-chat-hdr-close { 
        background: rgba(255,255,255,0.1); border: none; color: #fff; 
        width: 36px; height: 36px; border-radius: 50%; 
        cursor: pointer; font-size: 14px; display: flex; 
        align-items: center; justify-content: center; 
        transition: background 0.2s; 
      }
      .bagani-chat-hdr-close:hover { background: rgba(255,255,255,0.2); }

      /* ── Messages area ── */
      .bagani-chat-messages {
        flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 12px;
        scrollbar-width: none; z-index: 10;
      }
      .bagani-chat-messages::-webkit-scrollbar { display: none; }

      /* Message bubbles */
      .bagani-msg { max-width: 85%; font-size: 14px; padding: 14px 18px; line-height: 1.5; word-break: break-word; }
      .bagani-msg.bot { background: rgba(255,255,255,0.1); color: #fff; border-radius: 20px 20px 20px 6px; align-self: flex-start; }
      .bagani-msg.user { background: #FFC107; color: #111; border-radius: 20px 20px 6px 20px; align-self: flex-end; font-weight: 600; }

      /* Suggestions / Placeholder Pills */
      .bagani-chat-suggestions {
        display: flex; flex-direction: column; gap: 8px; margin-top: auto;
        padding: 0 24px 10px 24px; z-index: 10; align-items: flex-start;
      }
      .bagani-chat-suggestion-pill {
        background: rgba(255,255,255,0.1); color: #fff;
        padding: 12px 18px; border-radius: 20px; font-size: 13px; font-weight: 500;
        border: 1px solid rgba(255,255,255,0.05); cursor: pointer; text-align: left;
        width: fit-content; transition: background 0.2s ease, border 0.2s ease;
      }
      .bagani-chat-suggestion-pill:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.2); }
      .bagani-chat-messages:not(:empty) + .bagani-chat-suggestions {
         display: none;
      }

      /* Typing dots */
      .bagani-typing { display: flex; gap: 5px; padding: 14px 18px; background: rgba(255,255,255,0.1); border-radius: 20px 20px 20px 6px; align-self: flex-start; }
      .bagani-typing span { width: 6px; height: 6px; background: #fff; border-radius: 50%; animation: baganiDot 1.3s infinite; opacity: 0.4; }
      .bagani-typing span:nth-child(2) { animation-delay: 0.2s; }
      .bagani-typing span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes baganiDot { 0%,80%,100% { transform: translateY(0); } 40% { transform: translateY(-4px); } }

      /* ── Input row ── */
      .bagani-chat-input-row {
        padding: 10px 24px 24px 24px;
        z-index: 10;
      }
      .bagani-chat-input-wrapper {
        display: flex; align-items: center;
        background: rgba(255,255,255,0.1);        
        border-radius: 30px;
        padding: 4px 6px 4px 20px;
        transition: background 0.2s, box-shadow 0.2s, border-color 0.2s;
        border: 1px solid rgba(255,255,255,0.05);
      }
      .bagani-chat-input-wrapper:focus-within {
        background: rgba(255,255,255,0.15);
        box-shadow: 0 0 0 2px rgba(255,193,7,0.5);
        border-color: rgba(255,193,7,0.5);
      }
      .bagani-chat-input {
        flex: 1; background: transparent; border: none; 
        color: #fff; font-size: 14px; outline: none;
        padding: 12px 0; font-family: inherit;
      }
      .bagani-chat-input::placeholder { color: rgba(255,255,255,0.4); }
      .bagani-chat-send {
        width: 36px; height: 36px; border-radius: 50%;
        background: #FFC107; border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: #111; margin-left: 8px;
        transition: opacity 0.2s, transform 0.2s;
      }
      .bagani-chat-send:active { transform: scale(0.95); }
      .bagani-chat-send:disabled { opacity: 0.3; background: rgba(255,255,255,0.2); color: rgba(255,255,255,0.5); cursor: default; }

      /* ── FAB ── */
      .bagani-chat-fab {
        width: 60px; height: 60px; border-radius: 50%;
        background: linear-gradient(135deg, #0099FF 0%, #A033FF 100%);
        border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s;
      }
      .bagani-chat-fab svg { width: 28px; height: 28px; fill: #ffffff; }
      
      /* THIS IS KEY: Dismiss FAB instantly when opened */
      .bagani-chat-fab.open { 
        transform: scale(0); 
        opacity: 0; 
        pointer-events: none; 
      }
      
      /* Mobile optimizations */
      @media (max-width: 991px) {
        .bagani-chat-wrap { right: 16px; bottom: 20px; }
        .bagani-chat-popup { width: calc(100vw - 32px); height: calc(100svh - 40px); max-height: 520px; border-radius: 20px; }
      }
    </style>

    <div class="bagani-chat-wrap" id="baganiChatWrap">
      <!-- Chat popup -->
      <div class="bagani-chat-popup" id="baganiChatPopup" role="dialog" aria-label="Bagani AI Chat">
        
        <div class="bagani-chat-bg-watermark">Bagani</div>
        
        <!-- Header -->
        <div class="bagani-chat-header">
          <img class="bagani-chat-logo-img" src="/images/bagani-logo.png" alt="Bagani" onerror="this.src='/images/bagani-logo-black.png'">
          <button class="bagani-chat-hdr-close" id="baganiChatClose" aria-label="Close">&#x2715;</button>
        </div>
        
        <!-- Messages -->
        <div class="bagani-chat-messages" id="baganiMessages"></div>
        
        <!-- Starter Pills (Assembly Style) -->
        <div class="bagani-chat-suggestions">
          <button class="bagani-chat-suggestion-pill" onclick="document.getElementById('baganiChatInput').value=this.textContent;document.getElementById('baganiChatSend').click();">What Bagani oil is best for my motorcycle?</button>
          <button class="bagani-chat-suggestion-pill" onclick="document.getElementById('baganiChatInput').value=this.textContent;document.getElementById('baganiChatSend').click();">Where can I buy Bagani products?</button>
        </div>

        <!-- Input -->
        <div class="bagani-chat-input-row">
          <div class="bagani-chat-input-wrapper">
             <input class="bagani-chat-input" id="baganiChatInput" type="text" placeholder="Ask anything..." maxlength="400" autocomplete="off">
             <button class="bagani-chat-send" id="baganiChatSend" aria-label="Send">
               <svg viewBox="0 0 24 24" width="18" height="18"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" fill="currentColor"/></svg>
             </button>
          </div>
        </div>
      </div>

      <!-- FAB button — Messenger style -->
      <button class="bagani-chat-fab" id="baganiChatFab" aria-label="Chat with Bagani AI">
        <!-- Facebook Messenger logo -->
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 4C12.954 4 4 12.954 4 24c0 5.728 2.312 10.9 6.056 14.664L10 44l5.456-.056C17.824 45.248 20.836 46 24 46c11.046 0 20-8.954 20-20S35.046 4 24 4z" fill="white"/>
          <path d="M24 6C14.059 6 6 14.059 6 24c0 5.394 2.218 10.264 5.788 13.774L11.5 42l4.306-.05C17.878 43.228 20.853 44 24 44c9.941 0 18-8.059 18-18S33.941 6 24 6zm-2.5 26.5l-5-5.5 9.5-5-4.5 10.5zm9.5-10.5l-9.5 5 4.5-10.5 5 5.5z" fill="url(#msgGrad)"/>
          <defs>
            <linearGradient id="msgGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#0099FF"/>
              <stop offset="100%" stop-color="#A033FF"/>
            </linearGradient>
          </defs>
        </svg>
      </button>
    </div>

    <script>
    (function() {
      var MESSENGER_URL = 'https://www.facebook.com/baganioilph/';
      var STORAGE_KEY = 'baganiChatHistory';
      var fab = document.getElementById('baganiChatFab');
      var popup = document.getElementById('baganiChatPopup');
      var closeBtn = document.getElementById('baganiChatClose');
      var messages = document.getElementById('baganiMessages');
      var input = document.getElementById('baganiChatInput');
      var sendBtn = document.getElementById('baganiChatSend');
      var wrap = document.getElementById('baganiChatWrap');
      var isOpen = false;
      var isBusy = false;

      // ── Session tracking ─────────────────────────────────────
      var SESSION_ID = sessionStorage.getItem('baganiChatSessionId');
      if (!SESSION_ID) {
        SESSION_ID = 'sess_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        sessionStorage.setItem('baganiChatSessionId', SESSION_ID);
      }

      // ── Toggle open/close ───────────────────────────────────
      function toggleChat() {
        isOpen = !isOpen;
        popup.classList.toggle('open', isOpen);
        fab.classList.toggle('open', isOpen);
        if (isOpen && messages.children.length === 0) {
          var restored = loadHistory();
          // No bot greeting in assembly style naturally, but we can restore old chats.
        }
        if (isOpen) setTimeout(function() { input.focus(); }, 50);
      }

      if (fab) fab.addEventListener('click', toggleChat);
      if (closeBtn) closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        isOpen = false;
        popup.classList.remove('open');
        fab.classList.remove('open');
      });

      // ── Message helpers ─────────────────────────────────────
      function scrollBottom() { messages.scrollTop = messages.scrollHeight; }

      function saveHistory() {
        var items = [];
        var nodes = messages.querySelectorAll('.bagani-msg');
        nodes.forEach(function(el) {
          var next = el.nextElementSibling;
          items.push({
            role: el.classList.contains('user') ? 'user' : 'bot',
            text: el.textContent,
            showFacebook: !!(next && next.classList.contains('bagani-msg-cta'))
          });
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ ts: Date.now(), items: items }));
      }

      function loadHistory() {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return false;
        try {
          var data = JSON.parse(raw);
          if (Date.now() - data.ts > 86400000) { localStorage.removeItem(STORAGE_KEY); return false; }
          data.items.forEach(function(item) {
            if (item.role === 'user') addUserMessage(item.text, true);
            else addBotMessage(item.text, item.showFacebook, true);
          });
          return data.items.length > 0;
        } catch(e) { return false; }
      }

      function addBotMessage(text, showMessenger, skipSave) {
        var div = document.createElement('div');
        div.className = 'bagani-msg bot';
        div.textContent = text;
        messages.appendChild(div);
        if (showMessenger) {
          var cta = document.createElement('a');
          cta.className = 'bagani-msg-cta';
          cta.href = MESSENGER_URL;
          cta.target = '_blank';
          cta.rel = 'noopener';
          cta.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" fill="white"><path d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96C18.34 21.21 22 17.06 22 12.06C22 6.53 17.5 2.04 12 2.04Z"/></svg> Visit us on Facebook';
          messages.appendChild(cta);
          var ctaLink = document.createElement('a');
          ctaLink.className = 'bagani-msg-cta-link';
          ctaLink.href = MESSENGER_URL;
          ctaLink.target = '_blank';
          ctaLink.rel = 'noopener';
          ctaLink.textContent = 'facebook.com/baganioilph';
          messages.appendChild(ctaLink);
        }
        if (!skipSave) saveHistory();
        scrollBottom();
      }

      function addUserMessage(text, skipSave) {
        var div = document.createElement('div');
        div.className = 'bagani-msg user';
        div.textContent = text;
        messages.appendChild(div);
        if (!skipSave) saveHistory();
        scrollBottom();
      }

      function addTyping() {
        var div = document.createElement('div');
        div.className = 'bagani-typing';
        div.id = 'baganiTyping';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        scrollBottom();
        return div;
      }

      function removeTyping() {
        var el = document.getElementById('baganiTyping');
        if (el) el.remove();
      }

      // ── Send message ────────────────────────────────────────
      function sendMessage() {
        var text = (input.value || '').trim();
        if (!text || isBusy) return;
        input.value = '';
        addUserMessage(text);
        isBusy = true;
        sendBtn.disabled = true;
        var typing = addTyping();

        fetch('/.netlify/functions/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text, sessionId: SESSION_ID, pageUrl: window.location.pathname })
        }).then(function(r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        }).then(function(data) {
          if (data.error) throw new Error(data.error);
          removeTyping();
          var reply = data.reply || '';
          var sm = !!data.suggestMessenger || reply.indexOf('SUGGEST_MESSENGER') !== -1;
          var clean = reply.replace(/SUGGEST_MESSENGER/g, '').trim();
          addBotMessage(clean || 'Let me connect you with our team.', sm);
        }).catch(function() {
          removeTyping();
          addBotMessage("Sorry, I\u2019m having trouble right now. Please visit us on Facebook.", true);
        }).finally(function() { isBusy = false; sendBtn.disabled = false; input.focus(); });
      }

      if (sendBtn) sendBtn.addEventListener('click', sendMessage);
      if (input) input.addEventListener('keydown', function(e) { if (e.key === 'Enter') sendMessage(); });

    })();
    </script>
    {% endif %}
    <div id="extNewsModal" class="ext-news-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="External news details">
      <div class="ext-news-modal-box">
        <button class="ext-news-modal-close" id="extNewsModalClose" type="button" aria-label="Close">&times;</button>
        <div id="extNewsModalBody"></div>
      </div>
    </div>

    <!-- Global Download PDF Modal -->
    <div class="dl-modal-overlay" id="dlModal" role="dialog" aria-modal="true" aria-labelledby="dlModalTitle">
        <div class="dl-modal-card">
            <button class="dl-modal-close" onclick="window.closeDlModal()" aria-label="Close">&times;</button>
            <div id="dlFormArea">
                <h2 class="dl-modal-title" id="dlModalTitle">Download <span>Product Sheet</span></h2>
                <p class="dl-modal-subtitle">Fill in your details to download the product data sheet.</p>
                <form id="dlForm" novalidate>
                    <div class="row g-3">
                        <div class="col-12">
                            <input type="text" name="dl_name" class="form-control dl-field" placeholder="Full Name" required>
                        </div>
                        <div class="col-md-6">
                            <input type="email" name="dl_email" class="form-control dl-field" placeholder="Email Address" required>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="dl_phone" class="form-control dl-field" placeholder="Phone Number" required>
                        </div>
                        <div class="col-12">
                            <input type="text" name="dl_store" class="form-control dl-field" placeholder="Name of Store" required>
                        </div>
                        <div class="col-12">
                            <input type="text" name="dl_location" class="form-control dl-field" placeholder="Location / City" required>
                        </div>
                        <div class="col-12">
                            <textarea name="dl_inquiry" class="form-control dl-field" rows="3" placeholder="Inquiry" required></textarea>
                        </div>
                        <div class="col-12" style="margin-top:8px;">
                            <button type="submit" class="dl-submit-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10h5l-6 6-6-6h5V3h2v7zm-9 9h16v-2H4v2z"/></svg>
                                Download TDS
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div id="dlSuccessMsg" style="display:none; flex-direction:column; align-items:center; justify-content:center; padding:40px 0; text-align:center;">
                <div style="width:60px;height:60px;background:#FFC107;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#1c1c1c"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </div>
                <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;">Download Started!</h3>
                <p style="color:#888;font-size:14px;margin:0;">Your PDF should be downloading now.</p>
            </div>
        </div>
    </div>
    <script>
    window.openDlModal = function(pdfUrl, productName) {
        var modal = document.getElementById('dlModal');
        modal.dataset.pdfUrl = pdfUrl || '';
        modal.dataset.productName = productName || document.title;
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
    };
    window.closeDlModal = function() {
        var modal = document.getElementById('dlModal');
        modal.classList.remove('active');
        document.body.style.overflow = '';
        var form = document.getElementById('dlForm');
        if (form) {
            form.reset();
            form.querySelectorAll('.dl-field-error').forEach(function(f) { f.classList.remove('dl-field-error'); });
            form.querySelectorAll('.dl-field-msg').forEach(function(m) { m.remove(); });
            var submitBtn = form.querySelector('.dl-submit-btn');
            if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10h5l-6 6-6-6h5V3h2v7zm-9 9h16v-2H4v2z"/></svg> Download TDS'; }
        }
        var formArea = document.getElementById('dlFormArea');
        var successMsg = document.getElementById('dlSuccessMsg');
        if (formArea) formArea.style.display = '';
        if (successMsg) successMsg.style.display = 'none';
    };
    document.addEventListener('click', function(e) {
        if (e.target && e.target.id === 'dlModal') window.closeDlModal();
    });
    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('dlForm');
        if (!form) return;

        // Clear error on each field when user starts typing
        form.querySelectorAll('.dl-field').forEach(function(field) {
            field.addEventListener('input', function() {
                this.classList.remove('dl-field-error');
                var errEl = this.parentNode.querySelector('.dl-field-msg');
                if (errEl) errEl.remove();
            });
        });

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            // Validate all required fields
            var isValid = true;
            form.querySelectorAll('.dl-field[required]').forEach(function(field) {
                var val = field.value.trim();
                var isEmpty = !val;
                var isEmailInvalid = field.type === 'email' && val && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);

                field.classList.remove('dl-field-error');
                var existing = field.parentNode.querySelector('.dl-field-msg');
                if (existing) existing.remove();

                if (isEmpty || isEmailInvalid) {
                    field.classList.add('dl-field-error');
                    var msg = document.createElement('span');
                    msg.className = 'dl-field-msg';
                    msg.textContent = isEmpty ? 'This field is required.' : 'Enter a valid email address.';
                    field.parentNode.appendChild(msg);
                    isValid = false;
                }
            });

            if (!isValid) return;

            // Disable submit button to prevent double-submit
            var submitBtn = form.querySelector('.dl-submit-btn');
            if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

            var modal = document.getElementById('dlModal');
            var pdfUrl = modal.dataset.pdfUrl;
            var productName = modal.dataset.productName || document.title;
            var data = {
                name:       form.dl_name.value.trim(),
                email:      form.dl_email.value.trim(),
                phone:      form.dl_phone.value.trim(),
                store_name: form.dl_store.value.trim(),
                location:   form.dl_location.value.trim(),
                inquiry:    form.dl_inquiry.value.trim(),
                _subject:   'PDF Downloaded: ' + productName + ' — Bagani Oil',
                product:    productName
            };

            // Send lead data to email, then download PDF
            fetch('https://formsubmit.co/ajax/info@baganioil.ph', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data)
            })
            .catch(function(){})
            .finally(function() {
                if (pdfUrl) {
                    var a = document.createElement('a');
                    a.href = pdfUrl;
                    a.download = '';
                    a.target = '_blank';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                }
                document.getElementById('dlFormArea').style.display = 'none';
                document.getElementById('dlSuccessMsg').style.display = 'flex';
                setTimeout(window.closeDlModal, 2500);
            });
        });
    });
    </script>

    <!-- Sanity Live: client-side content fetching -->
    <script src="/js/sanity-live.js?v={{ buildVersion }}" defer></script>
</body>
</html>
