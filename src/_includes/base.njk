    <!-- Floating Navbar Script -->
    <script>
    (function() {
      var wrap = document.getElementById('bagani-header-wrap');
      var spacer = document.getElementById('header-spacer');

      function syncSpacer() {
        if (spacer && wrap) spacer.style.height = wrap.offsetHeight + 'px';
      }

      function onScroll() {
        var scrollY = window.scrollY || window.pageYOffset;
        if (scrollY > 40) {
          wrap.classList.add('scrolled');
        } else {
          wrap.classList.remove('scrolled');
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', syncSpacer);
      document.addEventListener('DOMContentLoaded', function() {
        syncSpacer();
        onScroll();

        // Nike-style search drawer toggle
        var searchToggle = document.getElementById('nikeSearchToggle');
        var searchDrawer = document.getElementById('nikeSearchDrawer');
        var searchClose = document.getElementById('nikeSearchClose');
        var searchInput = document.getElementById('nikeSearchInput');

        if (searchToggle && searchDrawer) {
          searchToggle.addEventListener('click', function() {
            searchDrawer.classList.toggle('open');
            if (searchDrawer.classList.contains('open') && searchInput) {
              setTimeout(function() { searchInput.focus(); }, 100);
            }
          });
        }
        if (searchClose && searchDrawer) {
          searchClose.addEventListener('click', function() {
            searchDrawer.classList.remove('open');
          });
        }
      });
      // re-sync after fonts/images load
      window.addEventListener('load', syncSpacer);
    })();
    </script>

    <!-- Language Toggle Script -->
    <script>
      // Swap all elements that have data-en and data-tl attributes
      function applyLang(lang) {
        document.querySelectorAll('[data-en]').forEach(function(el) {
          el.textContent = lang === 'tl' ? (el.getAttribute('data-tl') || el.getAttribute('data-en')) : el.getAttribute('data-en');
        });
        var btn = document.getElementById('langToggle');
        if (btn) {
          btn.textContent = lang === 'tl' ? 'Tagalog' : 'English';
          btn.style.color = lang === 'tl' ? '#121212' : '#FFFFFF';
          btn.style.background = lang === 'tl' ? '#FFC107' : 'none';
        }
        document.documentElement.setAttribute('lang', lang === 'tl' ? 'tl' : 'en');
        localStorage.setItem('bagani-lang', lang);
      }

      function toggleLang() {
        var current = localStorage.getItem('bagani-lang') || 'en';
        applyLang(current === 'en' ? 'tl' : 'en');
      }

      // Apply saved preference on load
      document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('bagani-lang') || 'en';
        if (saved === 'tl') applyLang('tl');
      });
    </script>

    <!-- Netlify Identity Redirect -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>

    {% if site.facebookPageId and site.facebookPageId != "YOUR_FACEBOOK_PAGE_ID" %}
    <!-- Bagani AI Chatbot Widget -->
    <style>
      /* ── Wrap ── */
      .bagani-chat-wrap {
        position: fixed; bottom: 24px; right: 24px; z-index: 9998;
        display: flex; align-items: flex-end; justify-content: flex-end;
      }

      /* ── Popup window (Bagani Dark Glass) ── */
      .bagani-chat-popup {
        width: 360px; height: 520px;
        background: rgba(28,28,28,0.95);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        overflow: hidden; 
        transform: scale(0.95) translateY(10px) translateX(10px);
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: bottom right;
        display: flex; flex-direction: column;
        position: absolute; bottom: 0; right: 0;
      }
      .bagani-chat-popup.open { opacity: 1; transform: scale(1) translateY(0) translateX(0); pointer-events: all; }

      /* Watermark */
      .bagani-chat-bg-watermark {
        position: absolute; top: 18%; left: 0; width: 100%;
        text-align: center; color: rgba(255,255,255,0.03);
        font-size: 64px; font-weight: 800; font-family: "Inter", sans-serif;
        pointer-events: none; z-index: 0; letter-spacing: 2px;
        text-transform: uppercase;
      }

      /* ── Header ── */
      .bagani-chat-header {
        padding: 24px 24px 10px 24px; 
        display: flex; align-items: center; justify-content: space-between;
        z-index: 10;
      }
      .bagani-chat-logo-img {
        max-width: 100px;
        max-height: 28px;
        object-fit: contain;
      }
      .bagani-chat-hdr-close { 
        background: rgba(255,255,255,0.1); border: none; color: #fff; 
        width: 36px; height: 36px; border-radius: 50%; 
        cursor: pointer; font-size: 14px; display: flex; 
        align-items: center; justify-content: center; 
        transition: background 0.2s; 
      }
      .bagani-chat-hdr-close:hover { background: rgba(255,255,255,0.2); }

      /* ── Messages area ── */
      .bagani-chat-messages {
        flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 12px;
        scrollbar-width: none; z-index: 10;
      }
      .bagani-chat-messages::-webkit-scrollbar { display: none; }

      /* Message bubbles */
      .bagani-msg { max-width: 85%; font-size: 14px; padding: 14px 18px; line-height: 1.5; word-break: break-word; }
      .bagani-msg.bot { background: rgba(255,255,255,0.1); color: #fff; border-radius: 20px 20px 20px 6px; align-self: flex-start; }
      .bagani-msg.user { background: #FFC107; color: #111; border-radius: 20px 20px 6px 20px; align-self: flex-end; font-weight: 600; }

      /* Suggestions / Placeholder Pills */
      .bagani-chat-suggestions {
        display: flex; flex-direction: column; gap: 8px; margin-top: auto;
        padding: 0 0 10px 0; z-index: 10; align-items: flex-start;
      }
      .bagani-chat-suggestion-pill {
        background: rgba(255,255,255,0.1); color: #fff;
        padding: 12px 18px; border-radius: 20px; font-size: 13px; font-weight: 500;
        border: 1px solid rgba(255,255,255,0.05); cursor: pointer; text-align: left;
        width: fit-content; transition: background 0.2s ease, border 0.2s ease;
      }
      .bagani-chat-suggestion-pill:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.2); }
      .bagani-chat-messages:not(:empty) + .bagani-chat-suggestions {
         display: none;
      }

      /* Typing dots */
      .bagani-typing { display: flex; gap: 5px; padding: 14px 18px; background: rgba(255,255,255,0.1); border-radius: 20px 20px 20px 6px; align-self: flex-start; }
      .bagani-typing span { width: 6px; height: 6px; background: #fff; border-radius: 50%; animation: baganiDot 1.3s infinite; opacity: 0.4; }
      .bagani-typing span:nth-child(2) { animation-delay: 0.2s; }
      .bagani-typing span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes baganiDot { 0%,80%,100% { transform: translateY(0); } 40% { transform: translateY(-4px); } }

      /* ── Input row ── */
      .bagani-chat-input-row {
        padding: 10px 24px 24px 24px;
        z-index: 10;
      }
      .bagani-chat-input-wrapper {
        display: flex; align-items: center;
        background: rgba(255,255,255,0.1);        
        border-radius: 30px;
        padding: 4px 6px 4px 20px;
        transition: background 0.2s, box-shadow 0.2s, border-color 0.2s;
        border: 1px solid rgba(255,255,255,0.05);
      }
      .bagani-chat-input-wrapper:focus-within {
        background: rgba(255,255,255,0.15);
        box-shadow: 0 0 0 2px rgba(255,193,7,0.5);
        border-color: rgba(255,193,7,0.5);
      }
      .bagani-chat-input {
        flex: 1; background: transparent; border: none; 
        color: #fff; font-size: 14px; outline: none;
        padding: 12px 0; font-family: inherit;
      }
      .bagani-chat-input::placeholder { color: rgba(255,255,255,0.4); }
      .bagani-chat-send {
        width: 36px; height: 36px; border-radius: 50%;
        background: #FFC107; border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: #111; margin-left: 8px;
        transition: opacity 0.2s, transform 0.2s;
      }
      .bagani-chat-send:active { transform: scale(0.95); }
      .bagani-chat-send:disabled { opacity: 0.3; background: rgba(255,255,255,0.2); color: rgba(255,255,255,0.5); cursor: default; }

      /* ── FAB ── */
      .bagani-chat-fab {
        width: 60px; height: 60px; border-radius: 50%;
        background: #FFC107;
        border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 6px 20px rgba(0,0,0,0.25);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s;
      }
      .bagani-chat-fab svg { width: 20px; height: 20px; fill: #222222; }
      
      /* THIS IS KEY: Dismiss FAB instantly when opened */
      .bagani-chat-fab.open { 
        transform: scale(0); 
        opacity: 0; 
        pointer-events: none; 
      }
      
      /* Mobile optimizations */
      @media (max-width: 991px) {
        .bagani-chat-wrap { right: 16px; bottom: 20px; }
        .bagani-chat-popup { width: calc(100vw - 32px); height: calc(100svh - 40px); max-height: 520px; border-radius: 20px; }
      }
    </style>

    <div class="bagani-chat-wrap" id="baganiChatWrap">
      <!-- Chat popup -->
      <div class="bagani-chat-popup" id="baganiChatPopup" role="dialog" aria-label="Bagani AI Chat">
        
        <div class="bagani-chat-bg-watermark">Bagani</div>
        
        <!-- Header -->
        <div class="bagani-chat-header">
          <img class="bagani-chat-logo-img" src="/images/bagani-logo.png" alt="Bagani" onerror="this.src='/images/bagani-logo-black.png'">
          <button class="bagani-chat-hdr-close" id="baganiChatClose" aria-label="Close">&#x2715;</button>
        </div>
        
        <!-- Messages -->
        <div class="bagani-chat-messages" id="baganiMessages"></div>
        
        <!-- Starter Pills (Assembly Style) -->
        <div class="bagani-chat-suggestions">
          <button class="bagani-chat-suggestion-pill" onclick="document.getElementById('baganiChatInput').value=this.textContent;document.getElementById('baganiChatSend').click();">I have a question about delivery and shipping</button>
          <button class="bagani-chat-suggestion-pill" onclick="document.getElementById('baganiChatInput').value=this.textContent;document.getElementById('baganiChatSend').click();">How do I choose the right oil?</button>
        </div>

        <!-- Input -->
        <div class="bagani-chat-input-row">
          <div class="bagani-chat-input-wrapper">
             <input class="bagani-chat-input" id="baganiChatInput" type="text" placeholder="Ask anything..." maxlength="400" autocomplete="off">
             <button class="bagani-chat-send" id="baganiChatSend" aria-label="Send">
               <svg viewBox="0 0 24 24" width="18" height="18"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" fill="currentColor"/></svg>
             </button>
          </div>
        </div>
      </div>

      <!-- FAB button -->
      <button class="bagani-chat-fab" id="baganiChatFab" aria-label="Chat with Bagani AI">
        <!-- Chat icon -->
        <svg class="icon-chat" viewBox="0 0 24 24"><path d="M20 2H4C2.9 2 2 2.9 2 4v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
      </button>
    </div>

    <script>
    (function() {
      var MESSENGER_URL = 'https://www.facebook.com/baganioilph/';
      var STORAGE_KEY = 'baganiChatHistory';
      var fab = document.getElementById('baganiChatFab');
      var popup = document.getElementById('baganiChatPopup');
      var closeBtn = document.getElementById('baganiChatClose');
      var messages = document.getElementById('baganiMessages');
      var input = document.getElementById('baganiChatInput');
      var sendBtn = document.getElementById('baganiChatSend');
      var wrap = document.getElementById('baganiChatWrap');
      var isOpen = false;
      var isBusy = false;

      // ── Toggle open/close ───────────────────────────────────
      function toggleChat() {
        isOpen = !isOpen;
        popup.classList.toggle('open', isOpen);
        fab.classList.toggle('open', isOpen);
        if (isOpen && messages.children.length === 0) {
          var restored = loadHistory();
          // No bot greeting in assembly style naturally, but we can restore old chats.
        }
        if (isOpen) setTimeout(function() { input.focus(); }, 50);
      }

      if (fab) fab.addEventListener('click', toggleChat);
      if (closeBtn) closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        isOpen = false;
        popup.classList.remove('open');
        fab.classList.remove('open');
      });

      // ── Message helpers ─────────────────────────────────────
      function scrollBottom() { messages.scrollTop = messages.scrollHeight; }

      function saveHistory() {
        var items = [];
        var nodes = messages.querySelectorAll('.bagani-msg');
        nodes.forEach(function(el) {
          var next = el.nextElementSibling;
          items.push({
            role: el.classList.contains('user') ? 'user' : 'bot',
            text: el.textContent,
            showFacebook: !!(next && next.classList.contains('bagani-msg-cta'))
          });
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ ts: Date.now(), items: items }));
      }

      function loadHistory() {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return false;
        try {
          var data = JSON.parse(raw);
          if (Date.now() - data.ts > 86400000) { localStorage.removeItem(STORAGE_KEY); return false; }
          data.items.forEach(function(item) {
            if (item.role === 'user') addUserMessage(item.text, true);
            else addBotMessage(item.text, item.showFacebook, true);
          });
          return data.items.length > 0;
        } catch(e) { return false; }
      }

      function addBotMessage(text, showMessenger, skipSave) {
        var div = document.createElement('div');
        div.className = 'bagani-msg bot';
        div.textContent = text;
        messages.appendChild(div);
        if (showMessenger) {
          var cta = document.createElement('a');
          cta.className = 'bagani-msg-cta';
          cta.href = MESSENGER_URL;
          cta.target = '_blank';
          cta.rel = 'noopener';
          cta.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" fill="white"><path d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96C18.34 21.21 22 17.06 22 12.06C22 6.53 17.5 2.04 12 2.04Z"/></svg> Visit us on Facebook';
          messages.appendChild(cta);
          var ctaLink = document.createElement('a');
          ctaLink.className = 'bagani-msg-cta-link';
          ctaLink.href = MESSENGER_URL;
          ctaLink.target = '_blank';
          ctaLink.rel = 'noopener';
          ctaLink.textContent = 'facebook.com/baganioilph';
          messages.appendChild(ctaLink);
        }
        if (!skipSave) saveHistory();
        scrollBottom();
      }

      function addUserMessage(text, skipSave) {
        var div = document.createElement('div');
        div.className = 'bagani-msg user';
        div.textContent = text;
        messages.appendChild(div);
        if (!skipSave) saveHistory();
        scrollBottom();
      }

      function addTyping() {
        var div = document.createElement('div');
        div.className = 'bagani-typing';
        div.id = 'baganiTyping';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        scrollBottom();
        return div;
      }

      function removeTyping() {
        var el = document.getElementById('baganiTyping');
        if (el) el.remove();
      }

      // ── Send message ────────────────────────────────────────
      function sendMessage() {
        var text = (input.value || '').trim();
        if (!text || isBusy) return;
        input.value = '';
        addUserMessage(text);
        isBusy = true;
        sendBtn.disabled = true;
        var typing = addTyping();

        fetch('/.netlify/functions/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text })
        })
        .then(function(r) {
          if (!r.ok) {
            console.error('Chat function error:', r.status, r.statusText);
            throw new Error('HTTP ' + r.status);
          }
          return r.json();
        })
        .then(function(data) {
          removeTyping();
          if (data.error) {
            addBotMessage("Sorry, I'm having trouble right now. Please try again or visit us on Facebook.", true);
          } else {
            addBotMessage(data.reply || "Let me connect you with our team.", data.suggestMessenger);
          }
        })
        .catch(function(err) {
          console.error('Chat error:', err.message);
          removeTyping();
          addBotMessage("Connection error. Please try again or reach us on Facebook.", true);
        })
        .finally(function() {
          isBusy = false;
          sendBtn.disabled = false;
          input.focus();
        });
      }

      if (sendBtn) sendBtn.addEventListener('click', sendMessage);
      if (input) input.addEventListener('keydown', function(e) { if (e.key === 'Enter') sendMessage(); });

      // ── Auto-open after 5s on first visit ───────────────────
      if (!sessionStorage.getItem('baganiChatSeen')) {
        setTimeout(function() {
          if (!isOpen) {
            toggleChat();
            sessionStorage.setItem('baganiChatSeen', '1');
          }
        }, 5000);
      }
    })();
    </script>
    {% endif %}
    <!-- Sanity Live: client-side content fetching -->
    <script src="/js/sanity-live.js"></script>
</body>
</html>
