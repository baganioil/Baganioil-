<!-- Footer Start -->
<footer class="main-footer">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="footer-header">
                    <div class="section-title dark-section">
                        <h2 class="text-anime-style-2" data-cursor="-opaque" data-en="Handa ka na ba sa kalidad na biyahe?" data-tl="Handa ka na ba sa kalidad na biyahe?">Handa ka na ba sa kalidad na biyahe?</h2>
                        <p data-en="BAGANI OIL - Langis ng Tunay na Bayani" data-tl="BAGANI OIL - Langis ng Tunay na Bayani">BAGANI OIL - Langis ng Tunay na Bayani</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-12">
                <div class="about-footer">
                    <div class="footer-logo">
                        <img src="/images/bagani-logo.png" alt="Bagani">
                    </div>
                    <div class="about-footer-content">
                        <p>Bagani OIl — De-kalidad na Langis kaagapay ng mga Bayani sa kalsada.</p>
                    </div>
                    <div class="footer-social-links">
                        <ul>
                            {% if site.social.pinterest %}<li><a href="{{ site.social.pinterest }}"><i class="fa-brands fa-pinterest-p"></i></a></li>{% endif %}
                            {% if site.social.twitter %}<li><a href="{{ site.social.twitter }}"><i class="fa-brands fa-x-twitter"></i></a></li>{% endif %}
                            {% if site.social.facebook %}<li><a href="{{ site.social.facebook }}"><i class="fa-brands fa-facebook-f"></i></a></li>{% endif %}
                            {% if site.social.instagram %}<li><a href="{{ site.social.instagram }}"><i class="fa-brands fa-instagram"></i></a></li>{% endif %}
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                <div class="footer-links">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="/">home</a></li>
                        <li><a href="/about/">about us</a></li>
                        <li><a href="/products/">products</a></li>
                        <li><a href="/news/">news</a></li>
                        {# STORES HIDDEN TEMPORARILY — uncomment to restore #}
                        {# <li><a href="/store-locator/">store locator</a></li> #}
                    </ul>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                <div class="footer-links">
                    <h3>Info</h3>
                    <ul>
                        <li><a href="#">term & condition</a></li>
                        <li><a href="#">privacy policy</a></li>
                        <li><a href="/faqs/">FAQ</a></li>
                        <li><a href="/contact/">contact us</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-12">
                <div class="footer-links">
                    <h3>Contact</h3>
                    <ul>
                        <li>{{ site.phone }}</li>
                        <li>{{ site.email }}</li>
                        <li>{{ site.address }}</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-copyright">
            <div class="row align-items-center">
                <div class="col-lg-12">
                    <div class="footer-copyright-text">
                        <p>Copyright &copy; {{ site.year }} Bagani Oil. All Rights Reserved.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
 </footer>
