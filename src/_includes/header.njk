<!-- Nike-Style Main Header -->
<header class="main-header">
    <div class="header-sticky">
        <nav class="navbar navbar-expand-lg">
            <div class="container nike-nav-container">
                <!-- Left: Logo -->
                <a class="navbar-brand" href="/">
                    <img src="/images/bagani-logo.png" alt="Bagani Logo">
                </a>

                <!-- Center: Main Nav Links -->
                <div class="collapse navbar-collapse main-menu">
                    <div class="nav-menu-wrapper">
                        <ul class="navbar-nav" id="menu">
                            <li class="nav-item"><a class="nav-link{% if activePage == 'home' %} active{% endif %}" href="/" data-en="Home" data-tl="Tahanan">Home</a></li>
                            <li class="nav-item"><a class="nav-link{% if activePage == 'about' %} active{% endif %}" href="/about/" data-en="About Us" data-tl="Tungkol Sa Amin">About Us</a></li>
                            <li class="nav-item"><a class="nav-link{% if activePage == 'products' %} active{% endif %}" href="/products/" data-en="Products" data-tl="Mga Produkto">Products</a></li>
                            <li class="nav-item"><a class="nav-link{% if activePage == 'news' %} active{% endif %}" href="/news/" data-en="News" data-tl="Balita">News</a></li>
                            {# STORES HIDDEN TEMPORARILY — uncomment to restore #}
                            {# <li class="nav-item"><a class="nav-link{% if activePage == 'stores' %} active{% endif %}" href="/store-locator/" data-en="Stores" data-tl="Mga Tindahan">Stores</a></li> #}
                            <li class="nav-item"><a class="nav-link{% if activePage == 'contact' %} active{% endif %}" href="/contact/" data-en="Contact" data-tl="Makipag-ugnayan">Contact</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Right: Action Icons (Nike-style) -->
                <div class="nike-nav-actions">
                    <!-- Expandable Search -->
                    <div class="expandable-search" style="margin-left: 8px;">
                        <input type="text" id="site-search-input" class="expandable-search-input" placeholder="Search..." autocomplete="off">
                        <button class="expandable-search-btn" aria-label="Search" tabindex="-1">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                        <div class="search-dropdown">
                            <!-- Shown when input is empty -->
                            <div class="search-most-searched" id="search-most-searched">
                                <div class="search-dropdown-title">Most Searched</div>
                                <ul class="search-dropdown-list">
                                    <li><a href="/products/">Performance Engine Oil</a></li>
                                    <li><a href="/about/">About Bagani</a></li>
                                </ul>
                            </div>
                            <!-- Shown when user types -->
                            <div class="search-results-pane" id="search-results-pane" style="display:none"></div>
                        </div>
                    </div>


                </div>

                <!-- Mobile: hamburger -->
                <div class="navbar-toggle"></div>
            </div>
        </nav>

<div class="responsive-menu"></div>
    </div>
</header>
<!-- Header End -->
