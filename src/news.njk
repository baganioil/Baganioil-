---
layout: base.njk
title: News
activePage: news
pageHeaderTitle: 'News & <span>Announcements</span>'
breadcrumbActive: news
---

{% include "page-header.njk" %}

<!-- Page News Start -->
<div class="page-blog">
    <div class="container">
        <div class="row">
            {% if articlesList and articlesList.length > 0 %}
                {% for article in articlesList %}
                <div class="col-lg-4 col-md-6">
                    <div class="post-item wow fadeInUp"{% if loop.index0 % 3 == 1 %} data-wow-delay="0.2s"{% elif loop.index0 % 3 == 2 %} data-wow-delay="0.4s"{% endif %}>
                        <div class="post-featured-image">
                            <figure>
                                <a href="/news/{{ article.slug }}/" class="image-anime" data-cursor-text="View">
                                    {% if article.image %}
                                    <img src="{{ article.image }}" alt="{{ article.title }}">
                                    {% else %}
                                    <img src="/images/post-1.jpg" alt="{{ article.title }}">
                                    {% endif %}
                                </a>
                            </figure>
                        </div>
                        <div class="post-item-body">
                            <div class="post-item-content">
                                {% if article.date %}<p class="post-date">{{ article.date }}</p>{% endif %}
                                <h2><a href="/news/{{ article.slug }}/">{{ article.title }}</a></h2>
                                {% if article.excerpt %}<p class="post-excerpt">{{ article.excerpt }}</p>{% endif %}
                            </div>
                            <div class="post-readmore-btn">
                                <a href="/news/{{ article.slug }}/">Read more</a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
            <div class="col-lg-12">
                <p style="text-align:center; padding: 60px 0; color: #888;">No articles published yet. Add articles in the Sanity Studio.</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>
<!-- Page News End -->
