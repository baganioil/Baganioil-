---
layout: base.njk
title: Products
activePage: products
pageHeaderTitle: 'Our <span>Products</span>'
breadcrumbActive: our products
pageHeaderBg: /images/our-products.jpg
---

{% include "page-header.njk" %}

<!-- Product Shop Start -->
<div class="page-services bagani-nike-shop wow fadeInUp">
    <div class="container nike-shop-container">
        <!-- TOP BAR -->
        <div class="nike-shop-topbar">
            <!-- Product Count -->
            <div class="topbar-count">
                All Products (<span id="product-count">{{ productsList | length }}</span>)
            </div>

            <div class="topbar-actions">
                <!-- Hide/Show Filters Button -->
                <button id="toggle-sidebar-btn" class="filter-toggle-btn">
                    <span id="toggle-filter-text">Hide Filters</span>
                    <i class="fa-solid fa-sliders"></i>
                </button>

                <!-- Sort Dropdown -->
                <div class="sort-dropdown">
                    <label for="sort-by">Sort By:</label>
                    <select id="sort-by">
                        <option value="original-order">Featured</option>
                        <option value="name">Name (A-Z)</option>
                        <option value="name-desc">Name (Z-A)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="nike-shop-main">
            <!-- LEFT SIDEBAR (Filters) -->
            <aside class="nike-shop-sidebar" id="nike-sidebar">
                <button id="mobile-close-sidebar" class="mobile-close-btn d-lg-none"><i class="fa-solid fa-xmark"></i></button>
                
                <!-- Group 1: Category / Line -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Category / Line <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".amihan" class="filter-check">
                            <span class="checkmark"></span> Amihan
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".laon" class="filter-check">
                            <span class="checkmark"></span> Laon
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".aman" class="filter-check">
                            <span class="checkmark"></span> Aman
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".anitun" class="filter-check">
                            <span class="checkmark"></span> Anitun
                        </label>
                    </div>
                </div>

                <!-- Group 2: Viscosity Grade (Placeholders based on spec) -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Viscosity Grade <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v10w40" class="filter-check">
                            <span class="checkmark"></span> 10W-40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v20w40" class="filter-check">
                            <span class="checkmark"></span> 20W-40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v0w20" class="filter-check">
                            <span class="checkmark"></span> 0W-20
                        </label>
                    </div>
                </div>
                
                <!-- Group 3: Engine Type (Placeholders based on spec) -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Engine Type <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".diesel" class="filter-check">
                            <span class="checkmark"></span> Diesel Engine
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".motorcycle-scooter" class="filter-check">
                            <span class="checkmark"></span> Motorcycle Scooter
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".gasoline" class="filter-check">
                            <span class="checkmark"></span> Gasoline Engine
                        </label>
                    </div>
                </div>
            </aside>

            <!-- PRODUCT GRID -->
            <div class="nike-shop-grid">
                <!-- Adding an overlay to click-close sidebar on mobile -->
                <div class="mobile-sidebar-overlay" id="mobile-overlay"></div>
                
                <div class="row project-item-boxes" id="sanity-products-grid">
                    <!-- Products loaded from Sanity -->
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Product Shop End -->

<script>
// Product Filter with Isotope (wait for jQuery to load)
window.addEventListener('load', function() {
    var $grid = $('.project-item-boxes').isotope({
        itemSelector: '.project-item-box',
        layoutMode: 'masonry',
        getSortData: {
            name: '.product-name'
        }
    });

    // Relayout after images load
    $grid.find('img').each(function() {
        var img = this;
        if (!img.complete) {
            img.addEventListener('load', function() { $grid.isotope('layout'); });
            img.addEventListener('error', function() { $grid.isotope('layout'); });
        }
    });

    // Sidebar Checkbox Filtering
    $('.filter-check').on('change', function() {
        // Single-select groups: uncheck all siblings when one is checked
        var $group = $(this).closest('.filter-group');
        if ($group.hasClass('single-select') && $(this).is(':checked')) {
            $group.find('.filter-check').not(this).prop('checked', false);
        }

        // Rebuild filter from all currently checked inputs
        var filters = [];
        $('.filter-check:checked').each(function() {
            filters.push($(this).val());
        });
        var filterValue = filters.length ? filters.join(', ') : '*';
        $grid.isotope({ filter: filterValue });

        // Update product count
        setTimeout(function() {
            var visibleItems = $grid.data('isotope').filteredItems.length;
            $('#product-count').text(visibleItems);
        }, 100);
    });

    // Sort Dropdown
    $('#sort-by').on('change', function() {
        var sortValue = $(this).val();
        if(sortValue === 'name') {
             $grid.isotope({ sortBy: 'name', sortAscending: true });
        } else if (sortValue === 'name-desc') {
             $grid.isotope({ sortBy: 'name', sortAscending: false });
        } else {
             $grid.isotope({ sortBy: 'original-order' });
        }
    });

    // Sidebar Slide Toggle
    $('#toggle-sidebar-btn').on('click', function() {
        var $shop = $('.bagani-nike-shop');
        if (window.innerWidth < 992) {
            // Mobile: slide in drawer
            $shop.toggleClass('mobile-sidebar-open');
        } else {
            // Desktop: collapse sidebar
            $shop.toggleClass('sidebar-hidden');
            if ($shop.hasClass('sidebar-hidden')) {
                $('#toggle-filter-text').text('Show Filters');
            } else {
                $('#toggle-filter-text').text('Hide Filters');
            }
            // Trigger Isotope layout recalculation
            setTimeout(function() { $grid.isotope('layout'); }, 300);
        }
    });

    // Mobile Close Action
    $('#mobile-close-sidebar, #mobile-overlay').on('click', function() {
        $('.bagani-nike-shop').removeClass('mobile-sidebar-open');
    });

    // Accordion Logic
    $('.filter-title').on('click', function() {
        var $group = $(this).parent('.filter-group');
        $group.toggleClass('expanded');
        var $icon = $(this).find('.toggle-icon');
        if($group.hasClass('expanded')) {
            $group.find('.filter-body').slideDown(300);
            $icon.removeClass('fa-chevron-down').addClass('fa-chevron-up');
        } else {
            $group.find('.filter-body').slideUp(300);
            $icon.removeClass('fa-chevron-up').addClass('fa-chevron-down');
        }
    });
});
</script>
