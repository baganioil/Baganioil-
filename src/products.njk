---
layout: base.njk
title: Products
activePage: products
pageHeaderTitle: 'Our <span>Products</span>'
breadcrumbActive: our products
pageHeaderBg: /images/our-products.jpg
---

{% include "page-header.njk" %}

<!-- Product Shop Start -->
<div class="page-services bagani-nike-shop">
    <div class="container nike-shop-container">
        <!-- TOP BAR -->
        <div class="nike-shop-topbar">
            <!-- Product Count -->
            <div class="topbar-count">
                All Products (<span id="product-count">{{ productsList | length }}</span>)
            </div>

            <div class="topbar-actions">
                <!-- Hide/Show Filters Button -->
                <button id="toggle-sidebar-btn" class="filter-toggle-btn">
                    <span id="toggle-filter-text">Hide Filters</span>
                    <i class="fa-solid fa-sliders"></i>
                </button>

                <!-- Sort Dropdown -->
                <div class="sort-dropdown">
                    <label for="sort-by">Sort By:</label>
                    <select id="sort-by">
                        <option value="original-order">Featured</option>
                        <option value="name">Name (A-Z)</option>
                        <option value="name-desc">Name (Z-A)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="nike-shop-main">
            <!-- LEFT SIDEBAR (Filters) -->
            <aside class="nike-shop-sidebar" id="nike-sidebar">
                <button id="mobile-close-sidebar" class="mobile-close-btn d-lg-none"><i class="fa-solid fa-xmark"></i></button>
                
                <!-- Group 1: Category / Line -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Category / Line <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".amihan" class="filter-check">
                            <span class="checkmark"></span> Amihan
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".laon" class="filter-check">
                            <span class="checkmark"></span> Laon
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".aman" class="filter-check">
                            <span class="checkmark"></span> Aman
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".anitun" class="filter-check">
                            <span class="checkmark"></span> Anitun
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".hilaya" class="filter-check">
                            <span class="checkmark"></span> Hilaya
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".gale" class="filter-check">
                            <span class="checkmark"></span> Gale
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".hanan" class="filter-check">
                            <span class="checkmark"></span> Hanan
                        </label>
                    </div>
                </div>

                <!-- Group 2: Viscosity Grade (Placeholders based on spec) -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Viscosity Grade <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v10w40" class="filter-check">
                            <span class="checkmark"></span> 10W-40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v15w40" class="filter-check">
                            <span class="checkmark"></span> 15W-40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v20w40" class="filter-check">
                            <span class="checkmark"></span> 20W-40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".v20w50" class="filter-check">
                            <span class="checkmark"></span> 20W-50
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".vsae40" class="filter-check">
                            <span class="checkmark"></span> SAE 40
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".vsae90" class="filter-check">
                            <span class="checkmark"></span> SAE 90 / 140
                        </label>
                    </div>
                </div>
                
                <!-- Group 3: Engine Type (Placeholders based on spec) -->
                <div class="filter-group expanded single-select">
                    <h4 class="filter-title">Engine Type <i class="fa-solid fa-chevron-up toggle-icon"></i></h4>
                    <div class="filter-body">
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".motorcycle-scooter" class="filter-check">
                            <span class="checkmark"></span> Motorcycle / Scooter
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".diesel" class="filter-check">
                            <span class="checkmark"></span> Diesel Engine
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".gasoline" class="filter-check">
                            <span class="checkmark"></span> Gasoline Engine
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".gear-oil" class="filter-check">
                            <span class="checkmark"></span> Gear Oil
                        </label>
                        <label class="filter-checkbox">
                            <input type="checkbox" value=".transmission" class="filter-check">
                            <span class="checkmark"></span> Transmission Fluid
                        </label>
                    </div>
                </div>
            </aside>

            <!-- PRODUCT GRID -->
            <div class="nike-shop-grid">
                <!-- Adding an overlay to click-close sidebar on mobile -->
                <div class="mobile-sidebar-overlay" id="mobile-overlay"></div>
                
                <div class="row project-item-boxes" id="sanity-products-grid">
                    <!-- Products loaded from Sanity -->
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Product Shop End -->

<script>
window.addEventListener('load', function() {
    var grid = document.getElementById('sanity-products-grid');

    // ── Filter ──────────────────────────────────────────────────────────────
    function applyCurrentFilters() {
        // Collect active filters grouped by filter-group (AND across groups, OR within group)
        var groupFilters = [];
        document.querySelectorAll('.filter-group').forEach(function(group) {
            var checked = [];
            group.querySelectorAll('.filter-check:checked').forEach(function(el) {
                checked.push(el.value.replace('.', ''));
            });
            if (checked.length > 0) groupFilters.push(checked);
        });

        var count = 0;
        document.querySelectorAll('#sanity-products-grid .project-item-box').forEach(function(item) {
            var show = groupFilters.length === 0 || groupFilters.every(function(group) {
                return group.some(function(f) { return item.classList.contains(f); });
            });
            item.style.display = show ? '' : 'none';
            if (show) count++;
        });
        var countEl = document.getElementById('product-count');
        if (countEl) countEl.textContent = count;
    }

    // Expose so sanity-live.js can call it after products load
    window.baganiApplyFilters = applyCurrentFilters;

    document.querySelectorAll('.filter-check').forEach(function(el) {
        el.addEventListener('change', function() {
            var group = this.closest('.filter-group');
            if (group && group.classList.contains('single-select') && this.checked) {
                group.querySelectorAll('.filter-check').forEach(function(sib) {
                    if (sib !== el) sib.checked = false;
                });
            }
            applyCurrentFilters();
        });
    });

    // Apply incoming URL filter, e.g. /products/?filter=amihan
    var initialFilter = new URLSearchParams(window.location.search).get('filter');
    var filterMap = { amihan: 'amihan', laon: 'laon', aman: 'aman', anitun: 'anitun' };
    if (initialFilter && filterMap[initialFilter]) {
        var targetClass = filterMap[initialFilter];
        document.querySelectorAll('.filter-group.single-select').forEach(function(group) {
            var target = group.querySelector('.filter-check[value=".' + targetClass + '"]');
            if (target) {
                group.querySelectorAll('.filter-check').forEach(function(sib) { sib.checked = false; });
                target.checked = true;
            }
        });
    }

    // ── Sort ────────────────────────────────────────────────────────────────
    var sortEl = document.getElementById('sort-by');
    if (sortEl) {
        sortEl.addEventListener('change', function() {
            if (!grid) return;
            var sortValue = this.value;
            var items = Array.from(grid.querySelectorAll('.project-item-box'));
            if (sortValue === 'name' || sortValue === 'name-desc') {
                items.sort(function(a, b) {
                    var na = (a.querySelector('.bagani-product-name') || {}).textContent || '';
                    var nb = (b.querySelector('.bagani-product-name') || {}).textContent || '';
                    return sortValue === 'name' ? na.localeCompare(nb) : nb.localeCompare(na);
                });
            } else {
                items.sort(function(a, b) { return (parseInt(a.dataset.idx) || 0) - (parseInt(b.dataset.idx) || 0); });
            }
            items.forEach(function(item) { grid.appendChild(item); });
        });
    }

    // ── Sidebar Toggle ──────────────────────────────────────────────────────
    var toggleBtn = document.getElementById('toggle-sidebar-btn');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
            var shop = document.querySelector('.bagani-nike-shop');
            if (window.innerWidth < 992) {
                shop.classList.toggle('mobile-sidebar-open');
            } else {
                shop.classList.toggle('sidebar-hidden');
                var textEl = document.getElementById('toggle-filter-text');
                if (textEl) textEl.textContent = shop.classList.contains('sidebar-hidden') ? 'Show Filters' : 'Hide Filters';
            }
        });
    }

    // ── Mobile Close ────────────────────────────────────────────────────────
    function closeMobile() { document.querySelector('.bagani-nike-shop').classList.remove('mobile-sidebar-open'); }
    var mClose = document.getElementById('mobile-close-sidebar');
    var mOverlay = document.getElementById('mobile-overlay');
    if (mClose) mClose.addEventListener('click', closeMobile);
    if (mOverlay) mOverlay.addEventListener('click', closeMobile);

    // ── Accordion ───────────────────────────────────────────────────────────
    document.querySelectorAll('.filter-title').forEach(function(title) {
        title.addEventListener('click', function() {
            var group = this.closest('.filter-group');
            var body = group.querySelector('.filter-body');
            var icon = this.querySelector('.toggle-icon');
            group.classList.toggle('expanded');
            if (group.classList.contains('expanded')) {
                body.style.display = '';
                icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
            } else {
                body.style.display = 'none';
                icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
            }
        });
    });
});
</script>
