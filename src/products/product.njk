---
pagination:
  data: productsList
  size: 1
  alias: product
permalink: "/products/{{ product.slug }}/"
layout: base.njk
activePage: products
eleventyComputed:
  title: "{{ product.name }}"
  pageHeaderTitle: "{{ product.name | safe }}"
---

<!-- Page Header Start -->
<div class="page-header product-page-header parallaxie">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="text-anime-style-2" data-cursor="-opaque">{{ product.name }} <span>{{ product.line }}</span></h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">home</a></li>
                            <li class="breadcrumb-item"><a href="/products/">products</a></li>
                            <li class="breadcrumb-item active" aria-current="page">{{ product.name }}</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Page Product Single Start -->
<div class="page-service-single">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="service-sidebar">
                    <!-- Product Lines List -->
                    <div class="service-catagery-list wow fadeInUp">
                        <h3>Product Lines</h3>
                        <ul>
                            <li><a href="/products/?filter=amihan">Amihan — Motorcycle Oils</a></li>
                            <li><a href="/products/?filter=laon">Laon — Engine Oils</a></li>
                            <li><a href="/products/?filter=aman">Aman — Gear Oils</a></li>
                            <li><a href="/products/?filter=anitun">Anitun — Transmission Fluids</a></li>
                        </ul>
                    </div>

                    <!-- Sidebar CTA -->
                    <div class="sidebar-cta-box wow fadeInUp" data-wow-delay="0.25s">
                        <div class="sidebar-cta-logo">
                            <img src="/images/bagani-logo.png" alt="Bagani">
                        </div>
                        <div class="sidebar-cta-Body">
                            <div class="sidebar-cta-content">
                                <h3>Need <span>help?</span></h3>
                                <p>Looking for the right oil for your motorcycle? Contact us for assistance.</p>
                            </div>
                            <div class="sidebar-cta-contact-list">
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-phone-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.phone }}</h3>
                                    </div>
                                </div>
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-mail-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.email }}</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-8">
                <div class="service-single-content">

                    <!-- Product Image -->
                    <div class="service-featured-image">
                        <figure class="image-anime reveal" style="background: linear-gradient(135deg, #FFF9E6 0%, #FFF3CC 100%); padding: 40px; text-align: center; border-radius: 10px;">
                            <img id="preview-product-img" src="{{ product.image }}" alt="Bagani {{ product.name }}" style="max-height: 400px; width: auto; object-fit: contain;">
                        </figure>
                    </div>

                    <!-- Product Video -->
                    {% if product.video %}
                    <div class="product-video wow fadeInUp" style="margin-top: 24px;">
                        <video controls style="width: 100%; border-radius: 10px; background: #000;">
                            <source src="{{ product.video }}" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                    {% endif %}

                    <!-- Product Info -->
                    <div class="service-entry">
                        <!-- Product Badge & Title -->
                        <div style="margin-bottom: 20px;">
                            <span id="preview-product-line" class="product-line" style="font-size: 13px; padding: 4px 14px; background: #FFC107; color: #121212; font-weight: 700; border-radius: 3px; text-transform: uppercase; letter-spacing: 1px;">{{ product.line }}</span>
                        </div>

                        <h2 id="preview-product-name" class="wow fadeInUp">{{ product.name }} — <span>{{ product.specs["Oil Type"] }}</span></h2>

                        <p id="preview-description" class="wow fadeInUp">{{ product.description }}</p>

                        <p id="preview-description2" class="wow fadeInUp" data-wow-delay="0.2s">{{ product.description2 }}</p>

                        <!-- Product Specifications Table -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.3s">Product <span>Specifications</span></h2>

                        <table class="product-specs-table wow fadeInUp" data-wow-delay="0.4s">
                            <tbody id="preview-specs-body">
                                {% for key, value in product.specs %}
                                <tr>
                                    <th>{{ key }}</th>
                                    <td>{{ value }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                        <!-- Key Features -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.4s">Key <span>Features</span></h2>

                        <div id="preview-features" class="service-entry-box">
                            {% for feature in product.features %}
                            <div class="service-entry-item">
                                <div class="icon-box">
                                    <img src="{{ feature.icon }}" alt="">
                                </div>
                                <div class="service-entry-item-content">
                                    <h3>{{ feature.title }}</h3>
                                    <p>{{ feature.desc }}</p>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <!-- Applications -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.4s">Recommended <span>Applications</span></h2>

                        <ul id="preview-applications">
                            {% for app in product.applications %}
                            <li>{{ app }}</li>
                            {% endfor %}
                        </ul>

                    </div>

                    <!-- Product FAQ -->
                    {% if product.faqs.length > 0 %}
                    <div class="our-faq-section">
                        <div class="section-title">
                            <h2 class="text-anime-style-3" data-cursor="-opaque">Frequently asked <span>questions</span></h2>
                        </div>

                        <div class="faq-accordion" id="faqaccordion">
                            {% for faq in product.faqs %}
                            <div class="accordion-item wow fadeInUp"{% if not loop.first %} data-wow-delay="{{ loop.index0 * 0.2 }}s"{% endif %}>
                                <h2 class="accordion-header" id="heading{{ loop.index }}">
                                    <button class="accordion-button{% if not loop.first %} collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="{% if loop.first %}true{% else %}false{% endif %}" aria-controls="collapse{{ loop.index }}">
                                        {{ faq.q }}
                                    </button>
                                </h2>
                                <div id="collapse{{ loop.index }}" class="accordion-collapse collapse{% if loop.first %} show{% endif %}" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#faqaccordion">
                                    <div class="accordion-body">
                                        <p>{{ faq.a }}</p>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    <!-- Back to Products Button -->
                    <div class="about-content-btn wow fadeInUp" style="margin-top: 30px;">
                        <a href="/products/" class="btn-default"><span>← Back to All Products</span></a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Product Single End -->

<script>
// Product draft preview — only runs when ?preview=true is in the URL
(function () {
  var params = new URLSearchParams(window.location.search);
  if (params.get('preview') !== 'true') return;

  var token = params.get('token') || '';
  var slug = location.pathname.replace(/^\/products\//, '').replace(/\/$/, '');
  if (!slug) return;

  var PROJECT_ID = 'c7mgn6k7';
  var DATASET = 'production';
  var API_VER = '2024-01-01';
  var query = '*[_type == "product" && slug.current == "' + slug + '"][0]{name,line,description,description2,"image":image.asset->url,"specs":specs[]{key,value},"features":features[]{title,desc,"icon":icon.asset->url},applications,"faqs":faqs[]{q,a}}';
  var url = 'https://' + PROJECT_ID + '.api.sanity.io/v' + API_VER + '/data/query/' + DATASET + '?query=' + encodeURIComponent(query) + '&perspective=previewDrafts';
  var opts = token ? { headers: { 'Authorization': 'Bearer ' + token } } : {};

  fetch(url, opts)
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var p = d.result;
      if (!p) return;

      var nameEl = document.getElementById('preview-product-name');
      if (nameEl) nameEl.innerHTML = p.name + (p.line ? ' — <span>' + p.line + '</span>' : '');

      var lineEl = document.getElementById('preview-product-line');
      if (lineEl && p.line) lineEl.textContent = p.line;

      var imgEl = document.getElementById('preview-product-img');
      if (imgEl && p.image) { imgEl.src = p.image; imgEl.alt = 'Bagani ' + (p.name || ''); }

      var desc1 = document.getElementById('preview-description');
      if (desc1 && p.description) desc1.textContent = p.description;

      var desc2 = document.getElementById('preview-description2');
      if (desc2 && p.description2) desc2.textContent = p.description2;

      var specsBody = document.getElementById('preview-specs-body');
      if (specsBody && p.specs && p.specs.length) {
        specsBody.innerHTML = p.specs.map(function (s) {
          return '<tr><th>' + (s.key || '') + '</th><td>' + (s.value || '') + '</td></tr>';
        }).join('');
      }

      var featuresEl = document.getElementById('preview-features');
      if (featuresEl && p.features && p.features.length) {
        featuresEl.innerHTML = p.features.map(function (f) {
          return '<div class="service-entry-item">' +
            (f.icon ? '<div class="icon-box"><img src="' + f.icon + '" alt=""></div>' : '') +
            '<div class="service-entry-item-content"><h3>' + (f.title || '') + '</h3><p>' + (f.desc || '') + '</p></div>' +
          '</div>';
        }).join('');
      }

      var appsEl = document.getElementById('preview-applications');
      if (appsEl && p.applications && p.applications.length) {
        appsEl.innerHTML = p.applications.map(function (a) { return '<li>' + a + '</li>'; }).join('');
      }
    })
    .catch(function (err) { console.warn('[Preview] Could not load draft product:', err); });
})();
</script>
