---
pagination:
  data: productsList
  size: 1
  alias: product
permalink: "/products/{{ product.slug }}/"
layout: base.njk
activePage: products
eleventyComputed:
  title: "{{ product.name }}"
  pageHeaderTitle: "{{ product.name | safe }}"
---

<!-- Page Header Start -->
<div class="page-header product-page-header parallaxie">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="text-anime-style-2" data-cursor="-opaque">{{ product.name }} <span>{{ product.line }}</span></h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">home</a></li>
                            <li class="breadcrumb-item"><a href="/products/">products</a></li>
                            <li class="breadcrumb-item active" aria-current="page">{{ product.name }}</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Page Product Single Start -->
<div class="page-service-single">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="service-sidebar">
                    <!-- Product Lines List -->
                    <div class="service-catagery-list wow fadeInUp">
                        <h3>Product Lines</h3>
                        <ul>
                            <li><a href="/products/?filter=amihan">Amihan — Motorcycle Oils</a></li>
                            <li><a href="/products/?filter=laon">Laon — Engine Oils</a></li>
                            <li><a href="/products/?filter=aman">Aman — Gear Oils</a></li>
                            <li><a href="/products/?filter=anitun">Anitun — Transmission Fluids</a></li>
                            <li><a href="/products/?filter=hanan">Hanan — Gasoline Engine Oils</a></li>
                        </ul>
                    </div>

                    <!-- Sidebar CTA -->
                    <div class="sidebar-cta-box wow fadeInUp" data-wow-delay="0.25s">
                        <div class="sidebar-cta-logo">
                            <img src="/images/bagani-logo.png" alt="Bagani">
                        </div>
                        <div class="sidebar-cta-Body">
                            <div class="sidebar-cta-content">
                                <h3>Need <span>help?</span></h3>
                                <p>Looking for the right oil for your vehicle? Contact us for assistance.</p>
                            </div>
                            <div class="sidebar-cta-contact-list">
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-phone-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.phone }}</h3>
                                    </div>
                                </div>
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-mail-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.email }}</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-8">
                <div class="service-single-content">

                    <!-- Product Image -->
                    {% if product.image %}
                    <div class="service-featured-image">
                        <figure class="image-anime reveal" style="border-radius: 10px; overflow: hidden; margin: 0; position: relative;">
                            <a href="{{ product.image }}" class="bagani-img-lightbox" title="{{ product.name }}" style="display: block; position: relative; cursor: zoom-in;">
                                <img src="{{ product.image }}" alt="Bagani {{ product.name }}" style="width: 100%; height: 480px; object-fit: cover; display: block;">
                                <span class="bagani-img-zoom-hint"><i class="fa-solid fa-magnifying-glass-plus"></i></span>
                            </a>
                        </figure>
                    </div>
                    {% endif %}

                    <!-- Product Video -->
                    {% if product.video %}
                    <div class="product-video wow fadeInUp" style="margin-top: 24px;">
                        <video controls style="width: 100%; border-radius: 10px; background: #000;">
                            <source src="{{ product.video }}" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                    {% endif %}

                    <!-- Product Info -->
                    <div class="service-entry">
                        <!-- Product Badge -->
                        <div style="margin-bottom: 20px;">
                            <span class="product-line" style="font-size: 13px; padding: 4px 14px; background: #FFC107; color: #121212; font-weight: 700; border-radius: 3px; text-transform: uppercase; letter-spacing: 1px;">{{ product.line }}</span>
                        </div>

                        <h2 class="wow fadeInUp">{{ product.name }}</h2>
                        <p class="wow fadeInUp">{{ product.description }}</p>

                        <!-- Product Benefits -->
                        {% if product.benefits and product.benefits.length > 0 %}
                        <span class="tds-section-label wow fadeInUp">Product Benefits</span>
                        <ul class="tds-benefits-list wow fadeInUp">
                            {% for b in product.benefits %}
                            <li>{% if b.title %}<strong>{{ b.title }}</strong> – {% endif %}{{ b.desc }}</li>
                            {% endfor %}
                        </ul>
                        {% endif %}

                        <!-- Application -->
                        {% if product.applicationText %}
                        <span class="tds-section-label wow fadeInUp">Application</span>
                        <div class="tds-text-block wow fadeInUp">
                            {% set paras = product.applicationText.split('\n') %}
                            {% for para in paras %}
                            {% if para %}<p>{{ para }}</p>{% endif %}
                            {% endfor %}
                        </div>
                        {% endif %}

                        <!-- Approvals & Available Sizes -->
                        {% if product.approvalsText %}
                        <span class="tds-section-label wow fadeInUp">Approvals</span>
                        <div class="tds-text-block wow fadeInUp">
                            <p>{{ product.approvalsText }}</p>
                        </div>
                        {% endif %}

                        {% if product.availableSizes and product.availableSizes.length > 0 %}
                        <span class="tds-section-label wow fadeInUp">Available Sizes</span>
                        <div class="tds-sizes-grid wow fadeInUp">
                            {% for size in product.availableSizes %}
                            <div class="tds-size-item">
                                {% if 'DRUM' in size %}
                                <img src="/images/icon-pkg-drum.svg" alt="Drum">
                                {% elif 'PAIL' in size %}
                                <img src="/images/icon-pkg-pail.svg" alt="Pail">
                                {% else %}
                                <img src="/images/icon-pkg-box.svg" alt="Box">
                                {% endif %}
                                <span class="size-label">{{ size }}</span>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <!-- Typical Properties -->
                        {% if product.typicalProperties %}
                        <span class="tds-section-label wow fadeInUp">Typical Properties</span>
                        <table class="tds-props-table wow fadeInUp">
                            {% if product.typicalProperties.grades and product.typicalProperties.grades.length > 0 %}
                            <thead>
                                <tr>
                                    <th>Properties</th>
                                    {% for grade in product.typicalProperties.grades %}
                                    <th>{{ grade }}</th>
                                    {% endfor %}
                                </tr>
                            </thead>
                            {% endif %}
                            <tbody>
                                {% for row in product.typicalProperties.rows %}
                                <tr>
                                    <th>{{ row.property }}</th>
                                    {% for val in row.values %}
                                    <td>{{ val }}</td>
                                    {% endfor %}
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                    </div>

                    <!-- Product FAQ -->
                    {% if product.faqs and product.faqs.length > 0 %}
                    <div class="our-faq-section">
                        <div class="section-title">
                            <h2 class="text-anime-style-3" data-cursor="-opaque">Frequently asked <span>questions</span></h2>
                        </div>

                        <div class="faq-accordion" id="faqaccordion">
                            {% for faq in product.faqs %}
                            <div class="accordion-item wow fadeInUp"{% if not loop.first %} data-wow-delay="{{ loop.index0 * 0.2 }}s"{% endif %}>
                                <h2 class="accordion-header" id="heading{{ loop.index }}">
                                    <button class="accordion-button{% if not loop.first %} collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="{% if loop.first %}true{% else %}false{% endif %}" aria-controls="collapse{{ loop.index }}">
                                        {{ faq.q }}
                                    </button>
                                </h2>
                                <div id="collapse{{ loop.index }}" class="accordion-collapse collapse{% if loop.first %} show{% endif %}" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#faqaccordion">
                                    <div class="accordion-body">
                                        <p>{{ faq.a }}</p>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    <!-- Product Image Lightbox -->
                    <div id="baganiLightbox" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;cursor:zoom-out;" onclick="this.style.display='none';document.body.style.overflow='';">
                        <img id="baganiLightboxImg" src="" alt="" style="max-width:92vw;max-height:92vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 40px rgba(0,0,0,0.6);pointer-events:none;">
                        <button onclick="event.stopPropagation();document.getElementById('baganiLightbox').style.display='none';document.body.style.overflow='';" style="position:absolute;top:20px;right:24px;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:22px;width:44px;height:44px;border-radius:50%;cursor:pointer;line-height:1;">&#x2715;</button>
                    </div>
                    <script>
                    (function() {
                        var lb = document.getElementById('baganiLightbox');
                        var lbImg = document.getElementById('baganiLightboxImg');
                        document.querySelectorAll('.bagani-img-lightbox').forEach(function(el) {
                            el.addEventListener('click', function(e) {
                                e.preventDefault();
                                lbImg.src = el.href;
                                lbImg.alt = el.title || '';
                                lb.style.display = 'flex';
                                document.body.style.overflow = 'hidden';
                            });
                        });
                        document.addEventListener('keydown', function(e) {
                            if (e.key === 'Escape') { lb.style.display = 'none'; document.body.style.overflow = ''; }
                        });
                    })();
                    </script>

                    <!-- Back to Products Button -->
                    <div class="about-content-btn wow fadeInUp" style="margin-top: 30px;">
                        <a href="/products/" class="btn-default"><span>← Back to All Products</span></a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Product Single End -->
