---
layout: base.njk
title: Product Detail
activePage: products
permalink: "/products/detail/"
---

<!-- Page Header Start -->
<div class="page-header product-page-header parallaxie">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="text-anime-style-2" data-cursor="-opaque" id="detail-heading">Loading<span id="detail-heading-line"></span></h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">home</a></li>
                            <li class="breadcrumb-item"><a href="/products/">products</a></li>
                            <li class="breadcrumb-item active" aria-current="page" id="detail-breadcrumb">Product</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Page Product Single Start -->
<div class="page-service-single">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="service-sidebar">
                    <div class="service-catagery-list wow fadeInUp">
                        <h3>Product Lines</h3>
                        <ul>
                            <li><a href="/products/?filter=amihan">Amihan — Motorcycle Oils</a></li>
                            <li><a href="/products/?filter=laon">Laon — Engine Oils</a></li>
                            <li><a href="/products/?filter=aman">Aman — Gear Oils</a></li>
                            <li><a href="/products/?filter=anitun">Anitun — Transmission Fluids</a></li>
                            <li><a href="/products/?filter=hanan">Hanan — Gasoline Engine Oils</a></li>
                        </ul>
                    </div>
                    <div class="sidebar-cta-box wow fadeInUp" data-wow-delay="0.25s">
                        <div class="sidebar-cta-logo">
                            <img src="/images/bagani-logo.png" alt="Bagani">
                        </div>
                        <div class="sidebar-cta-Body">
                            <div class="sidebar-cta-content">
                                <h3>Need <span>help?</span></h3>
                                <p>Looking for the right oil for your vehicle? Contact us for assistance.</p>
                            </div>
                            <div class="sidebar-cta-contact-list">
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-phone-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.phone }}</h3>
                                    </div>
                                </div>
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-mail-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.email }}</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-8">
                <div id="detail-content" style="padding: 60px 0; text-align: center; color: #aaa;">Loading product...</div>
            </div>
        </div>
    </div>
</div>
<!-- Page Product Single End -->

<script>
(function () {
    var PROJECT_ID = 'c7mgn6k7';
    var DATASET = 'production';
    var API_VER = '2024-01-01';

    var slug = '';
    var pathParts = window.location.pathname.replace(/\/$/, '').split('/');
    var lastPart = pathParts[pathParts.length - 1];
    if (lastPart && lastPart !== 'detail') {
        slug = lastPart;
    } else {
        slug = new URLSearchParams(window.location.search).get('p') || '';
    }

    if (!slug) {
        document.getElementById('detail-content').innerHTML = '<p style="color:#888;padding:60px 0">Product not found. <a href="/products/">Back to products</a></p>';
        return;
    }

    var query = '*[_type == "product" && slug.current == "' + slug.replace(/"/g, '') + '"][0]{' +
        'name, line, description,' +
        '"image": image.asset->url,' +
        '"video": video.asset->url,' +
        '"benefits": benefits[]{title, desc},' +
        '"features": features[]{title, desc},' +
        'applicationText,' +
        'applications,' +
        'approvalsText,' +
        'approvals,' +
        'availableSizes,' +
        '"typicalProperties": typicalProperties{grades, "rows": rows[]{property, values}},' +
        '"specs": specs[]{key, value},' +
        '"faqs": faqs[]{q, a},' +
        '"pdfUrl": pdfFile.asset->url' +
    '}';

    var url = '/.netlify/functions/sanity-query?query=' + encodeURIComponent(query);

    function getSizeIcon(size) {
        var s = (size || '').toUpperCase();
        if (s.indexOf('DRUM') > -1) return '/images/icon-pkg-drum.svg';
        if (s.indexOf('PAIL') > -1) return '/images/icon-pkg-pail.svg';
        return '/images/icon-pkg-box.svg';
    }

    function buildSizesHtml(sizes) {
        if (!sizes || !sizes.length) return '';
        return '<span class="tds-section-label">Available Sizes</span>' +
            '<div class="tds-sizes-grid">' +
            sizes.map(function (s) {
                return '<div class="tds-size-item">' +
                    '<img src="' + getSizeIcon(s) + '" alt="">' +
                    '<span class="size-label">' + s + '</span>' +
                '</div>';
            }).join('') +
            '</div>';
    }

    function buildPropsHtml(tp, specs) {
        // Prefer new typicalProperties format, fall back to Sanity specs array
        if (tp && tp.rows && tp.rows.length) {
            var headerRow = '';
            if (tp.grades && tp.grades.length) {
                headerRow = '<thead><tr><th>Properties</th>' +
                    tp.grades.map(function (g) { return '<th>' + g + '</th>'; }).join('') +
                '</tr></thead>';
            }
            return '<span class="tds-section-label">Typical Properties</span>' +
                '<table class="tds-props-table">' + headerRow + '<tbody>' +
                tp.rows.map(function (r) {
                    return '<tr><th>' + (r.property || '') + '</th>' +
                        (r.values || []).map(function (v) { return '<td>' + v + '</td>'; }).join('') +
                    '</tr>';
                }).join('') +
                '</tbody></table>';
        }
        if (specs && specs.length) {
            return '<span class="tds-section-label">Typical Properties</span>' +
                '<table class="tds-props-table"><tbody>' +
                specs.map(function (s) {
                    return '<tr><th>' + (s.key || '') + '</th><td>' + (s.value || '') + '</td></tr>';
                }).join('') +
                '</tbody></table>';
        }
        return '';
    }

    function buildBenefitsHtml(benefits, features) {
        var items = (benefits && benefits.length) ? benefits : (features && features.length ? features : null);
        if (!items) return '';
        return '<span class="tds-section-label">Product Benefits</span>' +
            '<ul class="tds-benefits-list">' +
            items.map(function (b) {
                var titlePart = (b.title) ? '<strong>' + b.title + '</strong> \u2013 ' : '';
                return '<li>' + titlePart + (b.desc || '') + '</li>';
            }).join('') +
            '</ul>';
    }

    function buildApplicationHtml(applicationText, applications) {
        var text = applicationText || (applications && applications.length ? applications.join('\n') : '');
        if (!text) return '';
        var paras = text.split('\n').filter(function (p) { return p.trim(); });
        return '<span class="tds-section-label">Application</span>' +
            '<div class="tds-text-block">' +
            paras.map(function (p) { return '<p>' + p + '</p>'; }).join('') +
            '</div>';
    }

    function buildApprovalsHtml(approvalsText, approvals) {
        var text = approvalsText || (approvals && approvals.length ? approvals.join('; ') : '');
        if (!text) return '';
        return '<span class="tds-section-label">Approvals</span>' +
            '<div class="tds-text-block"><p>' + text + '</p></div>';
    }

    function buildFaqsHtml(faqs) {
        if (!faqs || !faqs.length) return '';
        return '<div class="our-faq-section"><div class="section-title">' +
            '<h2 class="text-anime-style-3" data-cursor="-opaque">Frequently asked <span>questions</span></h2>' +
            '</div><div class="faq-accordion" id="faqaccordion">' +
            faqs.map(function (f, i) {
                return '<div class="accordion-item wow fadeInUp"' + (i > 0 ? ' data-wow-delay="' + (i * 0.2) + 's"' : '') + '>' +
                    '<h2 class="accordion-header" id="heading' + (i+1) + '">' +
                    '<button class="accordion-button' + (i > 0 ? ' collapsed' : '') + '" type="button" ' +
                    'data-bs-toggle="collapse" data-bs-target="#collapse' + (i+1) + '" ' +
                    'aria-expanded="' + (i === 0 ? 'true' : 'false') + '">' + f.q + '</button></h2>' +
                    '<div id="collapse' + (i+1) + '" class="accordion-collapse collapse' + (i === 0 ? ' show' : '') + '" ' +
                    'data-bs-parent="#faqaccordion"><div class="accordion-body"><p>' + f.a + '</p></div></div>' +
                '</div>';
            }).join('') +
            '</div></div>';
    }

    /* openDlModal / closeDlModal are defined globally in base.njk */

    fetch(url, { cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            var p = d.result;
            if (!p) {
                document.getElementById('detail-content').innerHTML =
                    '<p style="color:#888;padding:60px 0">Product not found. <a href="/products/">Back to products</a></p>';
                return;
            }

            var detailContent = document.getElementById('detail-content');
            detailContent.style.padding = '';
            detailContent.style.textAlign = '';
            detailContent.style.color = '';

            document.title = p.name + ' | Bagani Oil';
            var heading = document.getElementById('detail-heading');
            if (heading) heading.innerHTML = p.name;
            var bc = document.getElementById('detail-breadcrumb');
            if (bc) bc.textContent = p.name;

            document.getElementById('detail-content').innerHTML =
                '<div class="service-single-content">' +
                    (p.image ? '<div class="service-featured-image"><figure class="image-anime" style="border-radius:10px;overflow:hidden;margin:0;"><img src="' + p.image + '" alt="' + p.name + '" style="width:100%;height:480px;object-fit:cover;display:block;"></figure></div>' : '') +
                    (p.video ? '<div class="product-video wow fadeInUp" style="margin-top:24px;"><video controls style="width:100%;border-radius:10px;background:#000;"><source src="' + p.video + '" type="video/mp4"></video></div>' : '') +
                    '<div class="service-entry">' +
                        '<div style="margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">' +
                            '<span class="product-line" style="font-size:13px;padding:4px 14px;background:#FFC107;color:#121212;font-weight:700;border-radius:3px;text-transform:uppercase;letter-spacing:1px;">' + (p.line || '') + '</span>' +
                            '<button class="product-dl-btn" onclick="window.openDlModal(\'' + (p.pdfUrl || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'") + '\')">' +
                                '<span class="dl-icon-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg></span>' +
                                '<span class="dl-text">Download PDF</span>' +
                            '</button>' +
                        '</div>' +
                        '<h2 class="wow fadeInUp">' + p.name + '</h2>' +
                        (p.description ? '<p class="wow fadeInUp">' + p.description + '</p>' : '') +
                        buildBenefitsHtml(p.benefits, p.features) +
                        buildApplicationHtml(p.applicationText, p.applications) +
                        buildApprovalsHtml(p.approvalsText, p.approvals) +
                        buildSizesHtml(p.availableSizes) +
                        buildPropsHtml(p.typicalProperties, p.specs) +
                    '</div>' +
                    buildFaqsHtml(p.faqs) +
                    '<div class="about-content-btn wow fadeInUp" style="margin-top:30px;">' +
                        '<a href="/products/" class="btn-default"><span>← Back to All Products</span></a>' +
                    '</div>' +
                '</div>';

            if (typeof WOW !== 'undefined') new WOW({ offset: 0 }).init();
        })
        .catch(function () {
            document.getElementById('detail-content').innerHTML =
                '<p style="color:#888;padding:60px 0">Could not load product. <a href="/products/">Back to products</a></p>';
        });
})();
</script>


