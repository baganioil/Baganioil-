---
layout: base.njk
title: Store Locator
activePage: stores
pageHeaderTitle: 'Saan maaaring <span>bumili?</span>'
breadcrumbActive: store locator
---

{% include "page-header.njk" %}

<!-- Store Locator CSS -->
<style>
  #store-map {
    height: 500px;
    width: 100%;
    border-radius: 12px;
    z-index: 1;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08); /* Sophisticated, soft shadow to fit the theme */
  }

  .store-locator-section {
    padding: 60px 0;
  }

  .store-search-box {
    background: #fff;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    margin-bottom: 30px;
  }

  .store-search-box h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 16px;
    color: #121212;
  }

  .store-search-input {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .store-search-input input {
    flex: 1 1 100%;
    min-width: 200px;
    padding: 12px 16px;
    border: 2px solid #e5e5e5;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .store-search-input input:focus {
    border-color: #FFC107;
  }

  .btn-find {
    background: #FFC107;
    color: #121212;
    border: none;
    padding: 12px 24px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-find:hover {
    background: #e0a800;
  }

  .btn-locate {
    background: #121212;
    color: #fff;
    border: none;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-locate:hover {
    background: #333;
  }

  .store-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .store-card {
    background: #fff;
    border-radius: 8px;
    padding: 16px 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    border-left: 4px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .store-card:hover,
  .store-card.active {
    border-left-color: #FFC107;
    box-shadow: 0 4px 20px rgba(255,193,7,0.2);
  }

  .store-card h4 {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 4px;
    color: #121212;
  }

  .store-card p {
    font-size: 13px;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  .store-card .store-distance {
    display: inline-block;
    margin-top: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #FFC107;
    background: #FFF5D6;
    padding: 2px 10px;
    border-radius: 20px;
  }

  .store-card .store-phone {
    font-size: 12px;
    color: #888;
    margin-top: 4px;
  }

  .no-results {
    text-align: center;
    padding: 30px;
    color: #999;
    font-size: 14px;
  }

  /* Leaflet popup style override */
  .leaflet-popup-content-wrapper {
    border-radius: 8px !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
  }

  .map-popup h4 {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #121212;
  }

  .map-popup p {
    font-size: 12px;
    color: #666;
    margin: 0 0 4px;
    line-height: 1.4;
  }

  .map-popup a {
    font-size: 12px;
    color: #FFC107;
    font-weight: 600;
    text-decoration: none;
  }

  .section-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #FFC107;
    margin-bottom: 12px;
    display: block;
  }

  /* Mobile responsiveness */
  @media (min-width: 768px) {
    .store-search-input input {
      flex: 1;
    }
    .store-search-input button {
      flex: 0 0 auto;
    }
  }
  @media (max-width: 767px) {
    .btn-locate, .btn-find {
      width: 100%;
    }
    #store-map {
      height: 350px;
      margin-bottom: 30px;
    }
    .store-list {
      max-height: 400px;
    }
  }
</style>

<!-- Store Locator Start -->
<section class="store-locator-section">
  <div class="container">

    <!-- Section Title -->
    <div class="row section-row align-items-center" style="margin-bottom: 30px;">
      <div class="col-lg-6">
        <div class="section-title">
          <h3 class="wow fadeInUp">hanapin ang bagani</h3>
          <h2 class="text-anime-style-2" data-cursor="-opaque">Mga Piling Tindahan <span>at Distributors</span></h2>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="section-title-content wow fadeInUp" data-wow-delay="0.25s">
          <p>Hanapin ang Bagani Oil sa mga piling tindahan at distributors malapit sa'yo.</p>
        </div>
      </div>
    </div>

    <!-- Search Box -->
    <div class="row">
      <div class="col-lg-12">
        <div class="store-search-box wow fadeInUp">
          <h3><i class="fa-solid fa-magnifying-glass" style="color:#FFC107; margin-right:8px;"></i>Search Stores</h3>
          <div class="store-search-input">
            <input type="text" id="storeSearch" placeholder="Search by city or store name..." oninput="filterStores(this.value)">
            <button class="btn-locate" onclick="useMyLocation()">
              <i class="fa-solid fa-location-crosshairs" style="margin-right:6px;"></i>Use My Location
            </button>
            <button class="btn-find" onclick="filterStores(document.getElementById('storeSearch').value)">
              Find Store
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Map + List -->
    <div class="row">
      <!-- Map (no wow class — Leaflet needs the container visible to calculate size) -->
      <div class="col-lg-8">
        <div id="store-map"></div>
      </div>

      <!-- Store List -->
      <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.2s">
        <span class="section-label">{{ storesList | length }} Stores Found</span>
        <div class="store-list" id="storeList"></div>
      </div>
    </div>

    <!-- All Stores Table (below map, visible on mobile) -->
    <div class="row" style="margin-top: 50px;">
      <div class="col-lg-12">
        <div class="section-title">
          <h2 class="text-anime-style-2" data-cursor="-opaque">All <span>Store Locations</span></h2>
        </div>
        <div class="table-responsive wow fadeInUp" style="margin-top: 20px;">
          <table class="product-specs-table">
            <thead>
              <tr>
                <th>Store Name</th>
                <th>Address</th>
                <th>City</th>
                <th style="white-space: nowrap; min-width: 140px;">Phone</th>
              </tr>
            </thead>
            <tbody>
              {% for store in storesList %}
              <tr>
                <td><strong>{{ store.name }}</strong></td>
                <td>{{ store.address }}</td>
                <td>{{ store.city }}</td>
                <td style="white-space: nowrap;">{% if store.phone %}<a href="tel:{{ store.phone }}">{{ store.phone }}</a>{% else %}—{% endif %}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</section>
<!-- Store Locator End -->

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// ── Store data from CMS ──────────────────────────────────────
const STORES = [
  {% for store in storesList %}
  {
    slug: "{{ store.slug }}",
    name: {{ store.name | dump | safe }},
    address: {{ store.address | dump | safe }},
    city: {{ store.city | dump | safe }},
    phone: {{ store.phone | dump | safe }},
    lat: {{ store.lat }},
    lng: {{ store.lng }}
  }{% if not loop.last %},{% endif %}
  {% endfor %}
];

// ── Map setup ─────────────────────────────────────────────────
const map = L.map('store-map', { zoomControl: true }).setView([14.5995, 120.9842], 12);

// Premium Light tile layer — much better for the light theme!
L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
  attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
  subdomains: 'abcd',
  maxZoom: 20
}).addTo(map);

// Style the Leaflet zoom controls to match the light theme perfectly
document.addEventListener('DOMContentLoaded', function() {
  var style = document.createElement('style');
  style.textContent = `
    .leaflet-control-zoom a {
      background: #ffffff !important;
      color: #121212 !important;
      border: 1px solid #e5e5e5 !important;
    }
    .leaflet-control-zoom a:hover {
      background: #f8f9fa !important;
      color: #FFC107 !important;
    }
    .leaflet-popup-content-wrapper {
      background: #ffffff !important;
      color: #121212 !important;
      border: none !important;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
    }
    .leaflet-popup-tip {
      background: #ffffff !important;
    }
    .map-popup h4 { color: #121212 !important; }
    .map-popup p { color: #666 !important; }
    .map-popup a { color: #FFC107 !important; }
  `;
  document.head.appendChild(style);
});

// Custom gold marker icon
const baganiIcon = L.divIcon({
  html: '<div style="background:#FFC107; border:3px solid #121212; border-radius:50% 50% 50% 0; width:28px; height:28px; transform:rotate(-45deg); box-shadow:0 2px 8px rgba(0,0,0,0.3);"><div style="transform:rotate(45deg); width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:12px;">⛽</div></div>',
  className: '',
  iconSize: [28, 28],
  iconAnchor: [14, 28],
  popupAnchor: [0, -30]
});

// ── Markers ───────────────────────────────────────────────────
const markers = {};

STORES.forEach(store => {
  const marker = L.marker([store.lat, store.lng], { icon: baganiIcon })
    .addTo(map)
    .bindPopup(`
      <div class="map-popup">
        <h4>${store.name}</h4>
        <p><i class="fa-solid fa-location-dot" style="color:#FFC107;margin-right:4px;"></i>${store.address}</p>
        ${store.phone ? `<p><i class="fa-solid fa-phone" style="color:#FFC107;margin-right:4px;"></i><a href="tel:${store.phone}">${store.phone}</a></p>` : ''}
        <a href="https://www.google.com/maps/search/?api=1&query=${store.lat},${store.lng}" target="_blank" rel="noopener">
          Get Directions →
        </a>
      </div>
    `, { maxWidth: 220 });

  marker.on('click', () => highlightCard(store.slug));
  markers[store.slug] = marker;
});

// ── Store list render ─────────────────────────────────────────
function renderList(stores, userLat, userLng) {
  const list = document.getElementById('storeList');
  const label = document.querySelector('.section-label');

  if (!stores.length) {
    list.innerHTML = '<div class="no-results"><i class="fa-solid fa-store-slash" style="font-size:32px;color:#ddd;"></i><br>No stores found.<br>Try a different search.</div>';
    label.textContent = '0 Stores Found';
    return;
  }

  label.textContent = stores.length + ' Store' + (stores.length > 1 ? 's' : '') + ' Found';

  list.innerHTML = stores.map(store => {
    let distHtml = '';
    if (userLat !== undefined) {
      const dist = haversine(userLat, userLng, store.lat, store.lng);
      distHtml = `<span class="store-distance"><i class="fa-solid fa-route"></i> ${dist.toFixed(1)} km away</span>`;
    }
    return `
      <div class="store-card" id="card-${store.slug}" onclick="focusStore('${store.slug}')">
        <h4>${store.name}</h4>
        <p><i class="fa-solid fa-location-dot" style="color:#FFC107;margin-right:4px;"></i>${store.address}, ${store.city}</p>
        ${store.phone ? `<p class="store-phone"><i class="fa-solid fa-phone" style="margin-right:4px;"></i>${store.phone}</p>` : ''}
        ${distHtml}
      </div>
    `;
  }).join('');
}

// Initial render
renderList(STORES);

// ── Focus on store ────────────────────────────────────────────
function focusStore(slug) {
  const store = STORES.find(s => s.slug === slug);
  if (!store) return;
  map.setView([store.lat, store.lng], 15, { animate: true });
  markers[slug].openPopup();
  highlightCard(slug);
}

function highlightCard(slug) {
  document.querySelectorAll('.store-card').forEach(c => c.classList.remove('active'));
  const card = document.getElementById('card-' + slug);
  if (card) {
    card.classList.add('active');
    card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}

// ── Search filter ─────────────────────────────────────────────
function filterStores(query) {
  const q = (query || '').toLowerCase().trim();
  const filtered = q
    ? STORES.filter(s =>
        s.name.toLowerCase().includes(q) ||
        s.city.toLowerCase().includes(q) ||
        s.address.toLowerCase().includes(q)
      )
    : STORES;
  renderList(filtered);
}

// ── Use My Location ───────────────────────────────────────────
function useMyLocation() {
  const btn = document.querySelector('.btn-locate');
  btn.textContent = 'Locating...';
  btn.disabled = true;

  if (!navigator.geolocation) {
    alert('Geolocation is not supported by your browser.');
    btn.textContent = 'Use My Location';
    btn.disabled = false;
    return;
  }

  navigator.geolocation.getCurrentPosition(
    pos => {
      const { latitude, longitude } = pos.coords;

      // Add user marker
      L.marker([latitude, longitude], {
        icon: L.divIcon({
          html: '<div style="background:#2196F3; border:3px solid #fff; border-radius:50%; width:20px; height:20px; box-shadow:0 2px 8px rgba(0,0,0,0.4);"></div>',
          className: '',
          iconSize: [20, 20],
          iconAnchor: [10, 10]
        })
      }).addTo(map).bindPopup('<b>You are here</b>').openPopup();

      // Sort by distance
      const sorted = [...STORES].sort((a, b) =>
        haversine(latitude, longitude, a.lat, a.lng) -
        haversine(latitude, longitude, b.lat, b.lng)
      );

      renderList(sorted, latitude, longitude);
      map.setView([latitude, longitude], 13, { animate: true });

      // Auto-focus nearest store
      if (sorted.length) {
        setTimeout(() => focusStore(sorted[0].slug), 600);
      }

      btn.innerHTML = '<i class="fa-solid fa-location-crosshairs" style="margin-right:6px;"></i>Use My Location';
      btn.disabled = false;
    },
    err => {
      alert('Could not get your location. Please allow location access and try again.');
      btn.innerHTML = '<i class="fa-solid fa-location-crosshairs" style="margin-right:6px;"></i>Use My Location';
      btn.disabled = false;
    }
  );
}

// ── Haversine distance (km) ───────────────────────────────────
function haversine(lat1, lon1, lat2, lon2) {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon/2) * Math.sin(dLon/2);
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

// Force Leaflet to recalculate size — use both load event and a fallback timeout
function fixMapSize() { map.invalidateSize(); }
window.addEventListener('load', function() {
  setTimeout(fixMapSize, 200);
});
setTimeout(fixMapSize, 600);
setTimeout(fixMapSize, 1200);
</script>
