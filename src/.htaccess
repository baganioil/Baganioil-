DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # If the request is for a real file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Fallback for /products/{slug}/ URLs that don't have a built static page:
    # serve the dynamic detail loader (URL stays the same in the browser)
    RewriteCond %{REQUEST_URI} ^/products/[^/]+/?$
    RewriteRule ^ /products/detail/index.html [L]
</IfModule>
